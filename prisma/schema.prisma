generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Perfil {
  admin
  gestor
  vendedor
}

enum PapelVendedor {
  closer_lider
  closer_independente
  trainee
  sdr
}

enum CanalLead {
  bio
  anuncio
  evento
}

enum ClasseLead {
  A
  B
  C
}


enum StatusLead {
  aguardando
  em_abordagem
  convertido
  perdido
  nurturing
}

enum TracoCarater {
  esquizoide
  oral
  masoquista
  rigido
  nao_identificado
}

enum ResultadoCall {
  fechou
  nao_fechou
  reagendar
  sem_call
}

enum TipoInteracao {
  call
  whatsapp_enviado
  whatsapp_recebido
  nota
  email
  print_whatsapp
}

enum TipoFollowUp {
  whatsapp
  call
  email
}

enum StatusFollowUp {
  pendente
  executado
  atrasado
  cancelado
}

enum TipoTemplate {
  whatsapp
  email
}

enum ClasseTemplate {
  A
  B
  C
  todos
}

enum StatusMeta {
  em_andamento
  atingida
  nao_atingida
}

enum StatusProposta {
  rascunho
  enviada
  visualizada
  aceita
  recusada
}

enum TipoInteracaoSDR {
  curtiu
  comentou
  story
  seguiu
}

enum TemperaturaSDR {
  frio
  morno
  quente
}

enum TentouSolucao {
  sim
  nao
  parcialmente
}

enum DecisaoRota {
  convidar
  lixeira
}

enum AceitouDiagnostico {
  sim
  nao
  pendente
}

enum TomEmocional {
  desesperado
  racional
  resistente
  aberto
  fragil
}

enum ContextoFasePrint {
  detalhe
  handoff
}

// ==========================================
// TABELAS
// ==========================================

/// Tabela 1: usuarios
model Usuario {
  id         Int      @id @default(autoincrement())
  nome       String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  senhaHash  String   @map("senha_hash") @db.VarChar(255)
  perfil     Perfil
  ativo      Boolean  @default(true)
  fotoUrl    String?  @map("foto_url") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  vendedor     Vendedor?
  auditLogs    AuditLog[]
  notificacoes Notificacao[]

  @@map("usuarios")
}

/// Tabela 2: vendedores
model Vendedor {
  id               Int            @id @default(autoincrement())
  usuarioId        Int            @unique @map("usuario_id")
  nomeExibicao     String?        @map("nome_exibicao") @db.VarChar(100)
  telefoneWhatsapp String?        @map("telefone_whatsapp") @db.VarChar(20)
  papel            PapelVendedor
  classesAtendidas String[]       @map("classes_atendidas")
  scorePerformance Float          @default(0) @map("score_performance")
  leadsAtivos      Int            @default(0) @map("leads_ativos")
  leadsMax         Int            @default(30) @map("leads_max")
  totalConversoes  Int            @default(0) @map("total_conversoes")
  ticketMedio      Decimal        @default(0) @map("ticket_medio") @db.Decimal(10, 2)
  rankingPosicao   Int            @default(0) @map("ranking_posicao")
  ativo            Boolean        @default(true)
  acessoSdr        Boolean        @default(false) @map("acesso_sdr")

  usuario          Usuario        @relation(fields: [usuarioId], references: [id])
  leads            Lead[]
  interacoes       Interacao[]
  followUps        FollowUp[]
  metas            Meta[]
  gamificacao      Gamificacao[]
  propostas        Proposta[]
  funilHistorico   FunilHistorico[]
  sdrLeadsComoOperador  LeadSDR[] @relation("SdrOperador")
  sdrLeadsComoCloser    LeadSDR[] @relation("SdrCloserDestino")
  sdrInboundComoOperador LeadSDRInbound[] @relation("OperadorInbound")
  sdrInboundComoCloser   LeadSDRInbound[] @relation("CloserDestinoInbound")
  eventosAgenda          EventoAgenda[]   @relation("EventosAgenda")
  vendasComoCloser       Venda[]          @relation("VendaCloser")

  @@map("vendedores")
}

/// Tabela 3: leads
model Lead {
  id                  Int           @id @default(autoincrement())
  respondiId          String?       @unique @map("respondi_id") @db.VarChar(255)
  nome                String        @db.VarChar(255)
  telefone            String        @db.VarChar(20)
  email               String?       @db.VarChar(255)
  canal               CanalLead
  formularioTitulo    String?       @map("formulario_titulo") @db.VarChar(255)
  pontuacao           Int           @default(0)
  classe              ClasseLead
  etapaFunil          String        @default("novo") @map("etapa_funil") @db.VarChar(100)
  vendedorId          Int?          @map("vendedor_id")
  status              StatusLead    @default(aguardando)
  dadosRespondi       Json?         @map("dados_respondi")
  dorPrincipal        String?       @map("dor_principal")
  tracoCarater        TracoCarater? @map("traco_carater")
  objecaoPrincipal    String?       @map("objecao_principal")
  resultadoCall       ResultadoCall? @map("resultado_call")
  resumoConversa      String?       @map("resumo_conversa")
  proximaAcao         String?       @map("proxima_acao")
  proximaAcaoData     DateTime?     @map("proxima_acao_data")
  vendaRealizada      Boolean       @default(false) @map("venda_realizada")
  valorVenda          Decimal?      @map("valor_venda") @db.Decimal(10, 2)
  dataPreenchimento   DateTime?     @map("data_preenchimento")
  dataAtribuicao      DateTime?     @map("data_atribuicao")
  dataAbordagem       DateTime?     @map("data_abordagem")
  dataConversao       DateTime?     @map("data_conversao")
  previsaoFechamento  DateTime?     @map("previsao_fechamento")
  motivoPerda         String?       @map("motivo_perda")
  produtoHubla        String?       @map("produto_hubla") @db.VarChar(255)
  // Fase 1 — scoring V2 + tracking de aquisicao paga
  classificacao       String?       @db.VarChar(20)
  fbclid              String?       @db.VarChar(255)
  gclid               String?       @db.VarChar(255)
  // Fase 2 — atribuicao a campanha/criativo
  campanhaId          Int?          @map("campanha_id")
  criativoId          Int?          @map("criativo_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  vendedor            Vendedor?     @relation(fields: [vendedorId], references: [id])
  campanha            Campanha?     @relation(fields: [campanhaId], references: [id])
  criativo            Criativo?     @relation(fields: [criativoId], references: [id])
  interacoes          Interacao[]
  followUps           FollowUp[]
  funilHistorico      FunilHistorico[]
  propostas           Proposta[]
  duplicatasOrigem    PossivelDuplicata[] @relation("DuplicataOrigem")
  duplicatasDe        PossivelDuplicata[] @relation("DuplicataDuplicata")
  leadSdrOrigem       LeadSDR[]
  formularioRespostas FormularioResposta[]
  vendas              Venda[]

  @@index([campanhaId])
  @@index([criativoId])
  @@map("leads")
}

/// Tabela 4: interacoes
model Interacao {
  id            Int           @id @default(autoincrement())
  leadId        Int           @map("lead_id")
  vendedorId    Int           @map("vendedor_id")
  tipo          TipoInteracao
  conteudo      String?
  gravacaoUrl   String?       @map("gravacao_url") @db.VarChar(500)
  transcricao   String?
  resumoIa      String?       @map("resumo_ia")
  camposIa      Json?         @map("campos_ia")
  duracao       Int?
  createdAt     DateTime      @default(now()) @map("created_at")

  lead          Lead          @relation(fields: [leadId], references: [id])
  vendedor      Vendedor      @relation(fields: [vendedorId], references: [id])

  @@map("interacoes")
}

/// Tabela 5: follow_ups
model FollowUp {
  id               Int            @id @default(autoincrement())
  leadId           Int            @map("lead_id")
  vendedorId       Int            @map("vendedor_id")
  dataProgramada   DateTime       @map("data_programada")
  dataExecutada    DateTime?      @map("data_executada")
  tipo             TipoFollowUp
  status           StatusFollowUp @default(pendente)
  templateId       Int?           @map("template_id")
  mensagemEnviada  String?        @map("mensagem_enviada")
  createdAt        DateTime       @default(now()) @map("created_at")

  lead             Lead           @relation(fields: [leadId], references: [id])
  vendedor         Vendedor       @relation(fields: [vendedorId], references: [id])
  template         TemplateMensagem? @relation(fields: [templateId], references: [id])

  @@map("follow_ups")
}

/// Tabela 6: templates_mensagem
model TemplateMensagem {
  id          Int            @id @default(autoincrement())
  nome        String         @db.VarChar(100)
  conteudo    String
  etapaFunil  String?        @map("etapa_funil") @db.VarChar(100)
  classeLead  ClasseTemplate @default(todos) @map("classe_lead")
  tipo        TipoTemplate   @default(whatsapp)
  ativo       Boolean        @default(true)
  createdAt   DateTime       @default(now()) @map("created_at")

  followUps   FollowUp[]

  @@map("templates_mensagem")
}

/// Tabela 7: metas
model Meta {
  id           Int        @id @default(autoincrement())
  vendedorId   Int        @map("vendedor_id")
  periodo      String     @db.VarChar(20)
  valorMeta    Decimal    @map("valor_meta") @db.Decimal(10, 2)
  valorAtual   Decimal    @default(0) @map("valor_atual") @db.Decimal(10, 2)
  percentual   Float      @default(0)
  leadsMeta    Int?       @map("leads_meta")
  leadsAtual   Int        @default(0) @map("leads_atual")
  status       StatusMeta @default(em_andamento)
  createdAt    DateTime   @default(now()) @map("created_at")

  vendedor     Vendedor   @relation(fields: [vendedorId], references: [id])

  @@map("metas")
}

/// Tabela: metas_empresa
model MetaEmpresa {
  id         Int      @id @default(autoincrement())
  periodo    String   @unique @db.VarChar(7)
  valorMeta  Decimal  @map("valor_meta") @db.Decimal(12, 2)
  leadsMeta  Int?     @map("leads_meta")
  observacao String?  @db.Text
  criadoPor  Int?     @map("criado_por")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("metas_empresa")
}

/// Tabela 8: funil_historico
model FunilHistorico {
  id             Int       @id @default(autoincrement())
  leadId         Int       @map("lead_id")
  etapaAnterior  String?   @map("etapa_anterior") @db.VarChar(100)
  etapaNova      String?   @map("etapa_nova") @db.VarChar(100)
  vendedorId     Int?      @map("vendedor_id")
  motivo         String?
  createdAt      DateTime  @default(now()) @map("created_at")

  lead           Lead      @relation(fields: [leadId], references: [id])
  vendedor       Vendedor? @relation(fields: [vendedorId], references: [id])

  @@map("funil_historico")
}

/// Tabela: etapas_funil (configuração dinâmica)
/// Fase 2 — coluna `pipeline` e descritor/filtro (nao faz parte da chave unica).
/// Slug continua globalmente unico; novos pipelines usam prefixo (int_*, dg_*).
model EtapaFunil {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @db.VarChar(100)
  label     String   @db.VarChar(100)
  cor       String   @default("#6c5ce7") @db.VarChar(20)
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  tipo      String   @default("normal") @db.VarChar(20)
  pipeline  String   @default("comercial") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pipeline, ordem])
  @@map("etapas_funil")
}

/// Tabela 9: sla_config
model SlaConfig {
  id                      Int        @id @default(autoincrement())
  classeLead              ClasseLead @unique @map("classe_lead")
  tempoMaximoMinutos      Int        @map("tempo_maximo_minutos")
  alertaAmareloPct        Int        @default(50) @map("alerta_amarelo_pct")
  alertaVermelhoPct        Int        @default(80) @map("alerta_vermelho_pct")
  redistribuirAoEstourar  Boolean    @default(true) @map("redistribuir_ao_estourar")

  @@map("sla_config")
}

/// Tabela 10: gamificacao
model Gamificacao {
  id          Int      @id @default(autoincrement())
  vendedorId  Int      @map("vendedor_id")
  pontos      Int      @default(0)
  badges      Json     @default("[]")
  periodo     String   @db.VarChar(20)
  ranking     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  vendedor    Vendedor @relation(fields: [vendedorId], references: [id])

  @@map("gamificacao")
}

/// Tabela 11: audit_log
model AuditLog {
  id               Int      @id @default(autoincrement())
  usuarioId        Int?     @map("usuario_id")
  acao             String   @db.VarChar(50)
  entidade         String   @db.VarChar(50)
  entidadeId       Int?     @map("entidade_id")
  dadosAnteriores  Json?    @map("dados_anteriores")
  dadosNovos       Json?    @map("dados_novos")
  ip               String?  @db.VarChar(45)
  createdAt        DateTime @default(now()) @map("created_at")

  usuario          Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("audit_log")
}

/// Tabela 13: possiveis_duplicatas
model PossivelDuplicata {
  id             Int      @id @default(autoincrement())
  leadOrigemId   Int      @map("lead_origem_id")
  leadDuplicataId Int     @map("lead_duplicata_id")
  tipoMatch      String   @map("tipo_match") @db.VarChar(20) // 'telefone', 'email', 'ambos'
  status         String   @default("pendente") @db.VarChar(20) // 'pendente', 'confirmado', 'descartado', 'mergeado'
  resolvidoPor   Int?     @map("resolvido_por")
  resolvidoEm    DateTime? @map("resolvido_em")
  createdAt      DateTime @default(now()) @map("created_at")

  leadOrigem     Lead     @relation("DuplicataOrigem", fields: [leadOrigemId], references: [id])
  leadDuplicata  Lead     @relation("DuplicataDuplicata", fields: [leadDuplicataId], references: [id])

  @@map("possiveis_duplicatas")
}

/// Tabela 12: propostas
model Proposta {
  id              Int            @id @default(autoincrement())
  leadId          Int            @map("lead_id")
  vendedorId      Int            @map("vendedor_id")
  valor           Decimal        @db.Decimal(10, 2)
  status          StatusProposta @default(rascunho)
  urlDocumento    String?        @map("url_documento") @db.VarChar(500)
  aberturas       Int            @default(0)
  dataEnvio       DateTime?      @map("data_envio")
  dataAssinatura  DateTime?      @map("data_assinatura")
  createdAt       DateTime       @default(now()) @map("created_at")

  lead            Lead           @relation(fields: [leadId], references: [id])
  vendedor        Vendedor       @relation(fields: [vendedorId], references: [id])

  @@map("propostas")
}

/// Tabela: leads_sdr
model LeadSDR {
  id                    Int                @id @default(autoincrement())
  nome                  String             @db.VarChar(255)
  instagram             String             @db.VarChar(255)
  tipoInteracao         TipoInteracaoSDR   @map("tipo_interacao")
  dataPrimeiroContato   DateTime           @default(now()) @map("data_primeiro_contato")
  mensagemEnviada       String?            @map("mensagem_enviada")

  // F2 - Conexao
  respostaLead          String?            @map("resposta_lead")
  temperaturaInicial    TemperaturaSDR?    @map("temperatura_inicial")
  dorAparente           String?            @map("dor_aparente")

  // F3 - Qualificacao
  tentouSolucaoAnterior TentouSolucao?     @map("tentou_solucao_anterior")
  temperaturaFinal      TemperaturaSDR?    @map("temperatura_final")
  decisaoRota           DecisaoRota?       @map("decisao_rota")
  detalheSituacao       String?            @map("detalhe_situacao")

  // F4 - Convite
  aceitouDiagnostico    AceitouDiagnostico? @map("aceitou_diagnostico")

  // Kanban
  etapa                 String             @default("f1_abertura") @db.VarChar(50)
  ordem                 Int                @default(0)

  // Handoff
  whatsapp              String?            @db.VarChar(20)
  dataReuniao           DateTime?          @map("data_reuniao")
  fimReuniao            DateTime?          @map("fim_reuniao")
  closerDestinoId       Int?               @map("closer_destino_id")
  resumoSituacao        String?            @map("resumo_situacao")
  tomEmocional          TomEmocional?      @map("tom_emocional")
  oqueFuncionou         String?            @map("oque_funcionou")
  oqueEvitar            String?            @map("oque_evitar")
  fraseChaveLead        String?            @map("frase_chave_lead")
  resumoIa              String?            @map("resumo_ia")

  // Referencia cruzada
  leadCloserId          Int?               @map("lead_closer_id")
  handoffRealizadoEm    DateTime?          @map("handoff_realizado_em")

  // Analise IA
  analiseIaCache        Json?              @map("analise_ia_cache")

  // Operador
  operadorId            Int                @map("operador_id")

  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  deletedAt             DateTime?          @map("deleted_at")

  closerDestino         Vendedor?          @relation("SdrCloserDestino", fields: [closerDestinoId], references: [id])
  leadCloser            Lead?              @relation(fields: [leadCloserId], references: [id])
  operador              Vendedor           @relation("SdrOperador", fields: [operadorId], references: [id])
  prints                PrintConversaSDR[]

  @@map("leads_sdr")
}

/// Tabela: prints_conversa_sdr
model PrintConversaSDR {
  id            Int                 @id @default(autoincrement())
  leadSdrId     Int                 @map("lead_sdr_id")
  imagemUrl     String              @map("imagem_url") @db.VarChar(500)
  ordem         Int                 @default(0)
  contextoFase  ContextoFasePrint   @default(detalhe) @map("contexto_fase")
  analiseIA     Json?               @map("analise_ia")
  createdAt     DateTime            @default(now()) @map("created_at")

  leadSdr       LeadSDR             @relation(fields: [leadSdrId], references: [id], onDelete: Cascade)

  @@map("prints_conversa_sdr")
}

/// Tabela: leads_sdr_inbound
model LeadSDRInbound {
  id                Int       @id @default(autoincrement())
  nome              String    @db.VarChar(255)
  telefone          String    @db.VarChar(20)
  email             String?   @db.VarChar(255)
  dorPrincipal      String?   @map("dor_principal") @db.Text
  formularioOrigem  String?   @map("formulario_origem") @db.VarChar(255)
  dadosRespondi     Json?     @map("dados_respondi")

  operadorId        Int       @map("operador_id")
  operador          Vendedor  @relation("OperadorInbound", fields: [operadorId], references: [id])

  etapa             String    @default("novo_lead") @db.VarChar(50)
  classe            String?   @db.VarChar(10)

  observacoes       String?   @db.Text
  proximoPasso      String?   @map("proximo_passo") @db.Text

  dataReuniao       DateTime? @map("data_reuniao")
  fimReuniao        DateTime? @map("fim_reuniao")
  closerDestinoId   Int?      @map("closer_destino_id")
  closerDestino     Vendedor? @relation("CloserDestinoInbound", fields: [closerDestinoId], references: [id])
  leadCloserId      Int?      @map("lead_closer_id")

  ordem             Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  @@index([operadorId, etapa])
  @@index([telefone])
  @@map("leads_sdr_inbound")
}

/// Tabela 15: eventos_agenda
model EventoAgenda {
  id                  Int       @id @default(autoincrement())

  // Tipo: reuniao_sdr_instagram, reuniao_sdr_inbound, reuniao_manual, bloco_on, bloco_off, evento_personalizado
  tipo                String    @db.VarChar(30)
  titulo              String    @db.VarChar(255)
  descricao           String?   @db.Text

  // Quando
  inicio              DateTime
  fim                 DateTime

  // Dono (closer)
  vendedorId          Int       @map("vendedor_id")
  vendedor            Vendedor  @relation("EventosAgenda", fields: [vendedorId], references: [id])

  // Quem criou (pode ser admin, sdr, ou o próprio closer)
  criadoPorId         Int?      @map("criado_por_id")

  // Vínculos opcionais com leads
  leadId              Int?      @map("lead_id")
  leadSdrId           Int?      @map("lead_sdr_id")
  leadSdrInboundId    Int?      @map("lead_sdr_inbound_id")

  // Contato avulso (reunião sem lead vinculado)
  contatoNome         String?   @map("contato_nome") @db.VarChar(255)
  contatoTelefone     String?   @map("contato_telefone") @db.VarChar(20)

  // Cor (eventos personalizados)
  cor                 String?   @db.VarChar(20)

  // Status pós-reunião (só pra tipos reuniao_*)
  statusReuniao       String?   @map("status_reuniao") @db.VarChar(20)

  // Lembretes
  lembrete60Enviado   Boolean   @default(false) @map("lembrete_60_enviado")
  lembrete30Enviado   Boolean   @default(false) @map("lembrete_30_enviado")

  // Override de horário OFF
  marcadoEmHorarioOff Boolean   @default(false) @map("marcado_em_horario_off")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  @@index([vendedorId, inicio])
  @@index([inicio])
  @@map("eventos_agenda")
}

/// Tabela 14: notificacoes
model Notificacao {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  tipo      String   @db.VarChar(50)
  titulo    String   @db.VarChar(255)
  mensagem  String
  dados     Json?
  lida      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("notificacoes")
}

/// Tabela 16: formulario_respostas
/// Historico de preenchimentos de formularios por lead. Lead pode preencher
/// multiplos forms ao longo do tempo (ex: Diag Gratuito, depois Intensivao).
/// Lead.dadosRespondi e unico e apaga historico — esta tabela preserva.
model FormularioResposta {
  id                Int       @id @default(autoincrement())
  leadId            Int       @map("lead_id")
  formularioTipo    String    @map("formulario_tipo") @db.VarChar(50)
  formularioOrigem  String?   @map("formulario_origem") @db.VarChar(255)
  respostas         Json
  scoreCalculado    Int?      @map("score_calculado")
  classificacao     String?   @db.VarChar(20)
  submittedAt       DateTime  @map("submitted_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([formularioTipo, submittedAt])
  @@map("formulario_respostas")
}

/// Tabela 17: campanhas (Fase 2 — aquisicao paga)
/// Campanhas do Meta Ads (ou outras) organizadas por estrategia.
/// estrategia e String (nao enum) pra evitar migration a cada estrategia nova.
/// Valores esperados: "intensivao_pago" | "diag_gratuito_n1" | "diag_gratuito_n2".
/// gastoAcumulado e atualizado pelo job Meta Marketing API (Fase 3).
model Campanha {
  id              Int        @id @default(autoincrement())
  metaCampaignId  String?    @unique @map("meta_campaign_id") @db.VarChar(50)
  nome            String     @db.VarChar(255)
  estrategia      String     @db.VarChar(50)
  status          String     @default("ativa") @db.VarChar(20)
  budgetDiario    Decimal?   @map("budget_diario") @db.Decimal(10, 2)
  gastoAcumulado  Decimal    @default(0) @map("gasto_acumulado") @db.Decimal(12, 2)
  dataInicio      DateTime?  @map("data_inicio")
  dataFim         DateTime?  @map("data_fim")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  criativos       Criativo[]
  leads           Lead[]
  vendas          Venda[]

  @@index([estrategia, status])
  @@map("campanhas")
}

/// Tabela 18: criativos (Fase 2 — aquisicao paga)
/// Anuncios individuais dentro de uma Campanha.
/// formato / angulo / narrativa / origemProducao sao String (nao enum) pra
/// permitir experimentacao sem migration.
model Criativo {
  id              Int       @id @default(autoincrement())
  campanhaId      Int       @map("campanha_id")
  metaAdId        String?   @unique @map("meta_ad_id") @db.VarChar(50)
  nome            String    @db.VarChar(255)
  formato         String    @db.VarChar(30)
  angulo          String?   @db.VarChar(30)
  narrativa       String?   @db.VarChar(30)
  origemProducao  String?   @map("origem_producao") @db.VarChar(20)
  gastoAcumulado  Decimal   @default(0) @map("gasto_acumulado") @db.Decimal(12, 2)
  impressoes      BigInt    @default(0)
  cliques         Int       @default(0)
  ctr             Float?
  cpc             Decimal?  @db.Decimal(8, 4)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  campanha        Campanha  @relation(fields: [campanhaId], references: [id])
  leads           Lead[]
  vendas          Venda[]

  @@index([campanhaId])
  @@map("criativos")
}

/// Tabela 19: vendas (Fase 2 — refator central)
/// Entidade separada do Lead. Lead tem 1:N Vendas (D1: primeira cobranca
/// paga = recorrencia=false; cobrancas subsequentes = recorrencia=true).
/// hublaInvoiceId unique garante idempotencia contra retry do webhook Hubla.
/// campanhaId/criativoId opcionais: venda pode existir sem atribuicao
/// (ex: venda manual, lead antigo anterior a campanhas).
model Venda {
  id                  Int       @id @default(autoincrement())
  leadId              Int       @map("lead_id")
  campanhaId          Int?      @map("campanha_id")
  criativoId          Int?      @map("criativo_id")
  hublaInvoiceId      String?   @unique @map("hubla_invoice_id") @db.VarChar(100)
  produto             String?   @db.VarChar(255)
  valorTotal          Decimal   @map("valor_total") @db.Decimal(10, 2)
  taxas               Decimal   @default(0) @db.Decimal(10, 2)
  valorLiquido        Decimal?  @map("valor_liquido") @db.Decimal(10, 2)
  metodoPagamento     String?   @map("metodo_pagamento") @db.VarChar(30)
  parcelas            Int?
  orderBumpsAceitos   Json?     @map("order_bumps_aceitos")
  utmsCheckout        Json?     @map("utms_checkout")
  fbclidCheckout      String?   @map("fbclid_checkout") @db.VarChar(255)
  closerResponsavelId Int?      @map("closer_responsavel_id")
  origemVenda         String?   @map("origem_venda") @db.VarChar(50)
  recorrencia         Boolean   @default(false)
  dataPagamento       DateTime  @map("data_pagamento")
  cicloVendaDias      Int?      @map("ciclo_venda_dias")
  createdAt           DateTime  @default(now()) @map("created_at")

  lead                Lead       @relation(fields: [leadId], references: [id])
  campanha            Campanha?  @relation(fields: [campanhaId], references: [id], onDelete: Restrict)
  criativo            Criativo?  @relation(fields: [criativoId], references: [id], onDelete: Restrict)
  closerResponsavel   Vendedor?  @relation("VendaCloser", fields: [closerResponsavelId], references: [id], onDelete: Restrict)

  @@index([leadId])
  @@index([dataPagamento])
  @@index([campanhaId, dataPagamento])
  @@index([recorrencia, dataPagamento])
  @@map("vendas")
}
